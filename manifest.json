{
  "manifest_version": 3,
  "name": "New Tab",
  "description": "Group currently open Chrome tabs by domain with local summaries and close controls.",
  "version": "0.1.0",
  "permissions": ["history", "tabs", "storage", "scripting", "sessions"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "New Tab",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
